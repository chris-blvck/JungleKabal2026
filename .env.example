# Front-end (Vite) Angel Ops cloud sync
# Example: http://localhost:8787 in local dev, or your API domain in production
VITE_ANGEL_OPS_API_BASE=http://localhost:8787

# Optional: if set, dashboard sends this token in X-Admin-Token for write routes
VITE_ANGEL_OPS_ADMIN_TOKEN=change-me

# Server port for node API
ACADEMY_API_PORT=8787

# Optional: protects PUT/POST Angel Ops API routes server-side
ANGEL_OPS_ADMIN_TOKEN=change-me

# Backend CORS (set to your frontend domain in production)
CORS_ALLOW_ORIGIN=*

# Optional backend write-rate limit for Angel Ops write endpoints
ANGEL_OPS_RATE_LIMIT_WINDOW_MS=60000
ANGEL_OPS_RATE_LIMIT_MAX=60

# ── Payments / Solana ──────────────────────────────────────────────────────────
# Comma-separated list of SOL wallet addresses that receive payments
PAYMENT_WALLET_POOL=YourSolWalletAddress1,YourSolWalletAddress2
# Solana RPC endpoint (mainnet-beta by default)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Minutes before a pending payment expires (default 15)
PAYMENT_EXPIRY_MINUTES=15
# Interval in ms for auto-detection sweep (0 to disable, default 15000)
PAYMENT_AUTODETECT_INTERVAL_MS=15000

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_MINI_APP_URL=https://your-deployed-miniapp-url.vercel.app

# ── Telegram Mini App (Vite frontend) ─────────────────────────────────────────
# Bot username without the @ (used to build invite links)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
# API base URL for the mini app frontend
VITE_MINIAPP_API_BASE=http://localhost:8787
